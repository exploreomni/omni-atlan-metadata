{
  "id": "omni_connector",
  "name": "Omni Metadata Connector",
  "logo": "data:image/svg+xml;base64,",
  "config": {
    "properties": {
      "omni_base_url": {
        "type": "string",
        "required": true,
        "ui": {
          "label": "Omni API Base URL",
          "placeholder": "https://your-org.omniapp.co/api",
          "grid": 8
        }
      },
      "omni_api_token": {
        "type": "string",
        "required": true,
        "ui": {
          "widget": "password",
          "label": "Omni API Token",
          "placeholder": "Paste organization API key or PAT",
          "grid": 8
        }
      },
      "connection_epoch_ms": {
        "type": "string",
        "required": true,
        "ui": {
          "label": "Atlan Connection Epoch (ms)",
          "placeholder": "1747156800000",
          "help": "13-digit creation timestamp of the Atlan-side Omni Connection. Used as the QN namespace under default/omni/.",
          "grid": 4
        }
      },
      "page_size": {
        "type": "integer",
        "required": true,
        "ui": {
          "label": "Page Size",
          "placeholder": "50",
          "grid": 4
        }
      },
      "max_pages": {
        "type": "integer",
        "required": false,
        "ui": {
          "label": "Max Pages (optional)",
          "placeholder": "2",
          "grid": 4
        }
      },
      "verify_ssl": {
        "type": "boolean",
        "required": false,
        "ui": {
          "label": "Verify SSL",
          "grid": 3
        }
      },
      "timeout_seconds": {
        "type": "integer",
        "required": false,
        "ui": {
          "label": "HTTP Timeout Seconds",
          "placeholder": "30",
          "grid": 3
        }
      },
      "max_concurrency": {
        "type": "integer",
        "required": false,
        "ui": {
          "label": "Max Concurrent API Calls",
          "placeholder": "10",
          "grid": 4
        }
      },
      "rate_limit_rpm": {
        "type": "integer",
        "required": false,
        "ui": {
          "label": "API Rate Limit (req/min)",
          "placeholder": "60",
          "help": "Omni's default is 60 req/min. Set lower if you share the token with other jobs.",
          "grid": 4
        }
      },
      "atlan_source_connection_map": {
        "type": "string",
        "required": false,
        "ui": {
          "widget": "textarea",
          "label": "Atlan Source Connection Map (optional, for Source Table -> Topic lineage)",
          "placeholder": "{\"<omni_connection_id>\": \"default/snowflake/1700000000\"}",
          "grid": 8
        }
      },
      "save_output_local": {
        "type": "boolean",
        "required": false,
        "ui": {
          "label": "Write NDJSON output locally",
          "hidden": true,
          "grid": 5
        }
      },
      "output_file": {
        "type": "string",
        "required": false,
        "ui": {
          "label": "Output File",
          "hidden": true,
          "placeholder": "omni_entities.ndjson",
          "grid": 5
        }
      }
    },
    "steps": [
      {
        "id": "payload",
        "title": "Omni Connection & Extraction",
        "properties": [
          "omni_base_url",
          "omni_api_token",
          "connection_epoch_ms",
          "page_size",
          "max_pages",
          "verify_ssl",
          "timeout_seconds",
          "max_concurrency",
          "rate_limit_rpm",
          "atlan_source_connection_map"
        ]
      }
    ]
  }
}
